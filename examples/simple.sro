shell = `bash`;
var shell workdir = `echo $HOME/dev`;
sanctuary = $workdir;

pr sro {
    url = `git@github.com:infraflakes/sro.git`;
    dir = `sro`;
    sync = `ignore`;
}

fn check {
    log(`checking project...`);
    exec(`echo done`);
}

fn build {
    log(`building...`);
    exec(`echo build complete`);
}

seq pipeline {
    check(pr.sro);
    build(pr.sro);
}

par all {
    check(pr.sro);
    build(pr.sro);
}
