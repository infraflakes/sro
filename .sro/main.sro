import ./seq.sro;
import ./par.sro;

pr sro {

  fn init {
    exec(`nix develop -c make init`);
  }

  fn build {
    log(`Building sro CLI!`);
    exec(`nix develop -c make build`);
  }

  fn check {
    exec(`nix develop -c make fmt`);
  }

  fn test {
    exec(`nix develop -c make test`);
  }
}
